// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`ConfirmDialog Snapshot > renders nothing when closed 1`] = `""`;

exports[`ConfirmDialog Snapshot > renders open danger dialog correctly 1`] = `"<div class="confirm-dialog-backdrop" role="presentation"><div role="alertdialog" aria-modal="true" aria-labelledby="confirm-dialog-title" aria-describedby="confirm-dialog-message" class="confirm-dialog confirm-dialog--danger"><h3 id="confirm-dialog-title" class="confirm-dialog__title">Delete item</h3><p id="confirm-dialog-message" class="confirm-dialog__message">This action cannot be undone.</p><div class="confirm-dialog__actions"><button class="confirm-dialog__btn confirm-dialog__btn--cancel">Cancel</button><button class="confirm-dialog__btn confirm-dialog__btn--confirm">Confirm</button></div></div></div>"`;

exports[`ConfirmDialog Snapshot > renders open info dialog correctly 1`] = `"<div class="confirm-dialog-backdrop" role="presentation"><div role="alertdialog" aria-modal="true" aria-labelledby="confirm-dialog-title" aria-describedby="confirm-dialog-message" class="confirm-dialog confirm-dialog--info"><h3 id="confirm-dialog-title" class="confirm-dialog__title">Information</h3><p id="confirm-dialog-message" class="confirm-dialog__message">Please confirm your choice.</p><div class="confirm-dialog__actions"><button class="confirm-dialog__btn confirm-dialog__btn--cancel">Cancel</button><button class="confirm-dialog__btn confirm-dialog__btn--confirm">Confirm</button></div></div></div>"`;

exports[`ConfirmDialog Snapshot > renders open warning dialog correctly 1`] = `"<div class="confirm-dialog-backdrop" role="presentation"><div role="alertdialog" aria-modal="true" aria-labelledby="confirm-dialog-title" aria-describedby="confirm-dialog-message" class="confirm-dialog confirm-dialog--warning"><h3 id="confirm-dialog-title" class="confirm-dialog__title">Warning</h3><p id="confirm-dialog-message" class="confirm-dialog__message">Are you sure you want to proceed?</p><div class="confirm-dialog__actions"><button class="confirm-dialog__btn confirm-dialog__btn--cancel">Go back</button><button class="confirm-dialog__btn confirm-dialog__btn--confirm">Yes, proceed</button></div></div></div>"`;
