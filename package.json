{
  "name": "translate-by-mikko",
  "version": "2.1.3",
  "description": "Extension to translate web pages using multiple providers",
  "main": "index.js",
  "scripts": {
    "bench": "vitest bench",
    "build": "vite build && vite build --config vite.pdfjs.config.ts && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs dist/chunks/pdf.worker.min.mjs && vite build --config vite.content.config.ts",
    "build:all": "npm run build && npm run build:firefox",
    "build:fast": "vite build && vite build --config vite.content.config.ts",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "build:safari": "bash scripts/convert-safari.sh",
    "build:zip": "npm run build && npm run zip",
    "changeset": "changeset",
    "clean": "rimraf dist",
    "e2e": "npm run test:e2e",
    "format": "prettier --check package.json",
    "lint": "eslint .",
    "postinstall": "bash scripts/fetch-wasm-assets.sh",
    "pr": "bash scripts/pr.sh",
    "package:firefox": "npm run build:firefox && cd dist-firefox && bestzip ../translate-by-mikko-firefox-v$npm_package_version.xpi *",
    "release": "changeset publish",
    "secrets": "gitleaks detect --no-git",
    "serve": "http-server dist -p 8080",
    "serve:e2e": "http-server . -p 8080",
    "size": "npm run build && size-limit",
    "size:analyze": "npm run build && webpack-bundle-analyzer dist --port 8888",
    "size:report": "npm run build && size-limit --json > size-report.json",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=default",
    "test:coverage": "rm -rf coverage && mkdir -p coverage/.tmp && vitest run --coverage",
    "test:e2e": "npm run test:e2e:web && npm run test:e2e:harness",
    "test:e2e-pdf": "npm run test:pdf",
    "test:e2e-web": "npm run test:e2e:web",
    "test:e2e:pdf": "npm run test:pdf",
    "test:e2e:web": "playwright test e2e/extension-load.spec.ts e2e/extension-playwright.spec.ts e2e/translation-e2e.spec.ts e2e/auto-translate.spec.ts e2e/keyboard-shortcuts.spec.ts e2e/context-menu.spec.ts e2e/csp-model-loading.spec.ts e2e/webgpu-detection.spec.ts",
    "test:e2e:harness": "playwright test e2e/provider-switch.harness.spec.ts e2e/translation-cache.harness.spec.ts e2e/quota-exhaustion.harness.spec.ts e2e/streaming-cancel.harness.spec.ts e2e/multi-provider-failover.harness.spec.ts",
    "test:pdf": "vitest run src/pdfjs-entry.test.ts src/content/pdf-loader.test.ts src/content/pdf-translator.test.ts",
    "test:mutation": "stryker run",
    "test:mutation:core": "stryker run --mutate \"src/core/**/*.ts\" --mutate \"!src/core/**/*.test.ts\" --mutate \"!src/core/index.ts\"",
    "typecheck": "tsc --noEmit",
    "typecheck:popup": "tsc --noEmit --project tsconfig.json",
    "zip": "bestzip dist/translate-by-mikko-v$npm_package_version.zip dist/*",
    "test:e2e:firefox": "playwright test e2e/firefox-compat.spec.ts",
    "test:e2e:webgpu": "playwright test e2e/translategemma-webgpu.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0-or-later",
  "type": "commonjs",
  "size-limit": [
    {
      "name": "Background service worker",
      "path": "dist/background.js",
      "limit": "50 KB",
      "webpack": false
    },
    {
      "name": "Content script",
      "path": "dist/content.js",
      "limit": "80 KB",
      "webpack": false
    },
    {
      "name": "Popup interface",
      "path": "dist/assets/popup-*.js",
      "limit": "35 KB",
      "webpack": false
    },
    {
      "name": "Options page",
      "path": "dist/assets/options-*.js",
      "limit": "70 KB",
      "webpack": false
    },
    {
      "name": "Offscreen document",
      "path": "dist/assets/offscreen-*.js",
      "limit": "200 KB",
      "webpack": false
    }
  ],
  "devDependencies": {
    "@0xts/gitleaks-cli": "^0.1.3",
    "@changesets/changelog-github": "^0.5.1",
    "@changesets/cli": "^2.29.6",
    "@playwright/test": "^1.54.2",
    "@size-limit/file": "^11.1.5",
    "@size-limit/webpack": "^11.1.5",
    "@solidjs/testing-library": "^0.8.10",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.0.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@webgpu/types": "^0.1.69",
    "bestzip": "^2.2.1",
    "copyfiles": "^2.4.1",
    "electron": "^41.2.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.0",
    "fake-indexeddb": "^6.1.0",
    "globals": "^16.3.0",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.0",
    "prettier": "^3.3.2",
    "rimraf": "^6.0.1",
    "size-limit": "^11.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "webpack": "^5.95.0",
    "webpack-bundle-analyzer": "^4.10.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@wllama/wllama": "^2.3.7",
    "franc-min": "^6.2.0",
    "mupdf": "^1.26.4",
    "pdfjs-dist": "^5.4.54",
    "tesseract.js": "^7.0.0",
    "vite": "^7.3.1",
    "vite-plugin-solid": "^2.11.10"
  }
}
